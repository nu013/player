<!DOCTYPE html>
<html lang="bn">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>PHP / External Embed Player</title>

<style>
/* =======================================
পুরো পেজ black background
======================================= */
html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    background: #000;
    overflow: hidden;
}

/* ভিডিও / iframe wrapper */
#video-wrapper {
    width: 100vw;
    height: 100vh;
    position: relative;
}

/* =======================================
iframe পুরো স্ক্রিনে
======================================= */
iframe {
    width: 100%;
    height: 100%;
    border: none;
}

/* =======================================
ভিডিওর / iframe এর মাঝখানে লেখা
======================================= */
#centerText {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    color: yellow;
    font-size: 18px;
    font-weight: bold;
    background: rgba(0,0,0,0); /* transparent */
    padding: 0px;
    margin: 0px;
    z-index: 10;
}

/* =======================================
Volume hint icon
======================================= */
#volumeIcon {
    position: absolute;
    bottom: 11px;
    right: 105px;
    z-index: 1500;
    cursor: pointer;
    pointer-events: none;
}

#volumeIcon svg{
    fill: red;
    height: 32px;
    width: 32px;
    pointer-events: none;
}

</style>
</head>

<body>

<div id="video-wrapper">

    <!-- ==============================
    iframe লোড হচ্ছে
    ============================== -->
    <iframe id="iframePlayer"
        sandbox="allow-scripts allow-same-origin allow-presentation"
        src="https://streamcrichd.com/update/skysfotb.php"
        allowfullscreen>
    </iframe>

    <!-- ==============================
    ভিডিওর / iframe এর মাঝখানে লেখা
    ============================== -->
    <div id="centerText">
        Click 4/5 Times  🔊 Volume Button for UNMUTE
    </div>

    <!-- ==============================
    Volume hint icon
    ============================== -->
    <div id="volumeIcon">
        <svg viewBox="0 0 24 24">
            <path d="M11 5L6 9H2V15H6L11 19V5Z" fill="lime" stroke="red" stroke-width="2" stroke-linejoin="round"/>
            <path d="M15.5 8.5C16.8333 9.66667 17.5 11.1667 17.5 13C17.5 14.8333 16.8333 16.3333 15.5 17.5" stroke="red" stroke-width="2" stroke-linecap="round"/>
        </svg>
    </div>

</div>

<script>
/*
========================================
CENTER TEXT AUTO HIDE
========================================
5000 মানে ৫ সেকেন্ড পরে লেখা hide হবে
আপনি চাইলে পরিবর্তন করতে পারেন
*/
setTimeout(function() {
    document.getElementById("centerText").style.display = "none";
}, 5000);

/*
========================================
KEYBOARD SHORTCUTS / AUTOPLAY / SOUND HINT
========================================
কোনো video element নেই তাই iframe নিজেই play হবে
Volume / mute hint user দেখাবে text + icon
*/
document.addEventListener("keydown", function(e){
    // শুধু input / textarea বাদ
    const tag=document.activeElement.tagName.toLowerCase();
    if(tag==="input"||tag==="textarea") return;

    // এখানে শুধু hint text দেখানো বা future actions handle করা যাবে
    // যেমন: ArrowUp / ArrowDown / M key / Space etc
    // এখন iframeなので volume control browser side
    if(e.key==="m"||e.key==="M"){
        alert("Iframe volume control browser থেকে করুন!");
    }
});

</script>

</body>
</html>
